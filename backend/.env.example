# ── Azure AD service principal (Power BI) ──────────────────────────
# Fill these from your Azure App Registration.
# IMPORTANT: rotate the secret you pasted earlier — treat it as compromised.
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-rotated-client-secret

# Power BI API scope (leave as-is unless Microsoft changes it)
POWERBI_SCOPE=https://analysis.windows.net/powerbi/api/.default

# ── PostgreSQL ─────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=powerbi_backup
PGUSER=postgres
PGPASSWORD=postgres

# ── App ────────────────────────────────────────────────────────────
PORT=3000
# Cron for the weekly sync. Default: every Wednesday 06:00.
# Format: second minute hour day-of-month month day-of-week
SYNC_CRON=0 0 6 * * 3
# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:4200
